FROM eclipse-temurin:17-jdk-jammy

RUN apt-get update && apt-get install -y wget bash unzip

# Install Liquibase
RUN wget https://github.com/liquibase/liquibase/releases/download/v4.25.1/liquibase-4.25.1.tar.gz \
 && tar -xzf liquibase-4.25.1.tar.gz -C /opt \
 && mv /opt/liquibase-4.25.1 /opt/liquibase

ENV PATH="/opt/liquibase:${PATH}"

WORKDIR /app

COPY . /app

CMD ["sh", "-c", "liquibase --url=$DATABASE_URL --changeLogFile=db/changelog/master.xml update"]
