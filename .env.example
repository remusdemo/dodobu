# Local dev — individual host vars (ignored when DATABASE_URL is set)
DB_HOST=db
DB_NAME=dodobu
DB_USER=postgres
DB_PASSWORD=postgres

# Railway production — single connection string (preferred over individual vars)
# DATABASE_URL=postgresql://user:pass@host:5432/dodobu

PORT=5000
RESEND_API_KEY=
EMAIL_FROM=no-reply@memobud.com

# Must be your Railway domain in production (e.g. https://your-app.railway.app)
APP_BASE_URL=http://localhost:5000

# Enable testing endpoints (/testing) — leave off in production
TESTING_ENABLED=0

