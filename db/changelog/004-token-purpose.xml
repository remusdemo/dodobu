<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="add-purpose-to-token" author="remy">
        <addColumn tableName="event_link_token">
            <column name="purpose"
                    type="VARCHAR(20)"
                    defaultValue="general">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="add-verification-code-to-token" author="remy">
        <addColumn tableName="event_link_token">
            <column name="verification_code" type="VARCHAR(4)"/>
            <column name="verification_code_sent_at" type="TIMESTAMP"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
